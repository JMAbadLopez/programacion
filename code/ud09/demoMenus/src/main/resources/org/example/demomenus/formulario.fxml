<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER_LEFT" spacing="15" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="org.example.demomenus.FormularioController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-background-color: red; -fx-font-weight: bold; -fx-font-size: 20px;" text="Formulario de Registro" />

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Nombre:" />
        <TextField fx:id="txtNombre" promptText="Tu nombre" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Categoría:" />
        <ComboBox fx:id="comboCategoria" prefWidth="200" />
    </HBox>

    <CheckBox fx:id="chkAcepto" text="Acepto los términos y condiciones" />

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#limpiarFormularioButtonClick" text="Limpiar" />
        <Button onAction="#enviarFormularioButtonClick" text="Enviar" />
    </HBox>
</VBox>
