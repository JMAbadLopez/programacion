<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.app.FabricantesController">
    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>
    
    <Label style="-fx-font-size: 20px;" text="Gestión de Fabricantes" />
    <HBox alignment="TOP_RIGHT" spacing="10.0">
        <children>
         <Button mnemonicParsing="false" text="Nuevo fabricante" />
         <Button mnemonicParsing="false" style="-fx-background-color: #34c9eb;" text="Actualizar" textFill="WHITE" />
         <Button mnemonicParsing="false" style="-fx-background-color: #e34242;" text="Eliminar" textFill="WHITE" />
        </children>
    </HBox>
    
    <TableView fx:id="tablaFabricantes">
        <columns>
            <TableColumn fx:id="colId" text="ID" />
            <TableColumn fx:id="colNombre" text="Nombre" />
        </columns>
    </TableView>


    <Button onAction="#nuevoArticulo" text="Nuevo artículo" />
    <Label text="⚠️ Selecciona un fabricante para añadir un nuevo artículo" />
</VBox>
